meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "cliente@gymflow.dev",
    "password": "Password123"
  }
}

vars:post-response {
  accessToken: res.body.data.accessToken
  refreshToken: res.body.data.refreshToken
}

